<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Find and Replace" Height="700" Width="700" Background="#F5F6F7" WindowStartupLocation="CenterScreen" FontFamily="Segoe UI">
    
    <Window.Resources>
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#D0D0D0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="RowBackground" Value="White"/>
            <Setter Property="AlternatingRowBackground" Value="#F9F9F9"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#EAEAEA"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderBrush" Value="#D0D0D0"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
        </Style>
    </Window.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <GroupBox Grid.Row="0" Header="Category to Search" Margin="0,0,0,15" Padding="10" BorderBrush="#D0D0D0">
            <UniformGrid Columns="3">
                <RadioButton x:Name="rbSheetNames" Content="Sheet Names" IsChecked="True" Checked="CategoryChanged" Margin="0,5"/>
                <RadioButton x:Name="rbRoomNames" Content="Room Names" Checked="CategoryChanged" Margin="0,5"/>
                <RadioButton x:Name="rbViewNames" Content="View Names" Checked="CategoryChanged" Margin="0,5"/>
                <RadioButton x:Name="rbSheetNumbers" Content="Sheet Numbers" Checked="CategoryChanged" Margin="0,5"/>
                <RadioButton x:Name="rbRoomNumbers" Content="Room Numbers" Checked="CategoryChanged" Margin="0,5"/>
                <RadioButton x:Name="rbViewTitles" Content="View Titles" Checked="CategoryChanged" Margin="0,5"/>
                <RadioButton x:Name="rbMaterials" Content="Materials" Checked="CategoryChanged" Margin="0,5"/>
                <RadioButton x:Name="rbTextNotes" Content="Text Notes" Checked="CategoryChanged" Margin="0,5"/>
                <RadioButton x:Name="rbLevels" Content="Levels" Checked="CategoryChanged" Margin="0,5"/>
            </UniformGrid>
        </GroupBox>

        <Grid Grid.Row="1" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Column="0" Grid.Row="0" Margin="0,0,0,10">
                <TextBlock Text="Find:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <TextBox x:Name="txtFind" TextChanged="InputChanged" Padding="4" Height="26"/>
                <CheckBox x:Name="chkCaseSensitive" Content="Match Case" Checked="InputChanged" Unchecked="InputChanged" Margin="0,5,0,0" IsChecked="True"/>
            </StackPanel>

            <StackPanel Grid.Column="2" Grid.Row="0" Margin="0,0,0,10">
                <TextBlock Text="Replace With:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <TextBox x:Name="txtReplace" TextChanged="InputChanged" Padding="4" Height="26"/>
                <CheckBox x:Name="chkCapitalize" Content="Force ALL CAPS" Checked="InputChanged" Unchecked="InputChanged" Margin="0,5,0,0"/>
            </StackPanel>

            <StackPanel Grid.Column="0" Grid.Row="1" Margin="0,0,0,10">
                <TextBlock Text="Add Prefix:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <TextBox x:Name="txtPrefix" TextChanged="InputChanged" Padding="4" Height="26"/>
            </StackPanel>

            <StackPanel Grid.Column="2" Grid.Row="1" Margin="0,0,0,10">
                <TextBlock Text="Add Suffix:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <TextBox x:Name="txtSuffix" TextChanged="InputChanged" Padding="4" Height="26"/>
            </StackPanel>
        </Grid>

        <DataGrid x:Name="dataGrid" Grid.Row="2" AutoGenerateColumns="False" CanUserAddRows="False" SelectionMode="Single" RowHeight="28">
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Setter Property="ContextMenu">
                        <Setter.Value>
                            <ContextMenu>
                                <MenuItem Header="Select in Revit" Click="SelectElement"/>
                                <MenuItem Header="Show in View" Click="ShowElement"/>
                            </ContextMenu>
                        </Setter.Value>
                    </Setter>
                </Style>
            </DataGrid.RowStyle>

            <DataGrid.Columns>
                <DataGridTextColumn Header="Reference" Binding="{Binding Reference}" Width="120" IsReadOnly="True"/>
                <DataGridTextColumn Header="Original Name" Binding="{Binding OriginalName}" Width="*" IsReadOnly="True"/>
                
                <DataGridTemplateColumn Header="New Name" Width="*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <ContentControl Content="{Binding FormattedNewName}" VerticalAlignment="Center" Margin="4,0,0,0"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridCheckBoxColumn Header="Include" Binding="{Binding Include}" Width="60">
                    <DataGridCheckBoxColumn.ElementStyle>
                        <Style TargetType="CheckBox">
                            <Setter Property="HorizontalAlignment" Value="Center"/>
                        </Style>
                    </DataGridCheckBoxColumn.ElementStyle>
                </DataGridCheckBoxColumn>
            </DataGrid.Columns>
        </DataGrid>

        <Grid Grid.Row="3" Margin="0,15,0,0">
            <TextBlock Text="Right-click a row to select or show element in Revit." Foreground="#777777" VerticalAlignment="Center"/>
            <Button Content="Apply Changes" Width="120" Height="32" HorizontalAlignment="Right" Background="#0072C6" Foreground="White" FontWeight="Bold" BorderThickness="0" Click="ApplyChanges"/>
        </Grid>
    </Grid>
</Window>